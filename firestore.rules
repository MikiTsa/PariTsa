rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================
    // HELPER FUNCTIONS
    // ========================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUserData() {
      let requiredFields = ['uid', 'email', 'createdAt'];
      let allowedFields  = ['uid', 'email', 'displayName', 'createdAt'];

      return request.resource.data.keys().hasAll(requiredFields)
          && request.resource.data.keys().hasOnly(allowedFields)
          && request.resource.data.uid        is string
          && request.resource.data.email      is string
          && request.resource.data.createdAt  is timestamp
          && (
               !request.resource.data.keys().hasAny(['displayName']) ||
               request.resource.data.displayName is string
             );
    }

    // Only call this on create/update — request.resource is null on read/delete.
    function isValidCategoryData() {
      return request.resource.data.keys().hasOnly(['items'])
          && request.resource.data.items is list;
    }

    function isValidTransaction() {
      let requiredFields = ['id', 'title', 'amount', 'date'];
      let allowedFields  = ['id', 'title', 'amount', 'date', 'category', 'note', 'tag'];

      return request.resource.data.keys().hasAll(requiredFields)
          && request.resource.data.keys().hasOnly(allowedFields)
          && request.resource.data.id     is string
          && request.resource.data.title  is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 100
          && request.resource.data.amount is number
          && request.resource.data.amount > 0
          && request.resource.data.amount <= 999999999
          && request.resource.data.date   is timestamp
          && (
               !request.resource.data.keys().hasAny(['category']) ||
               request.resource.data.category is string
             )
          && (
               !request.resource.data.keys().hasAny(['note']) ||
               request.resource.data.note is string
             )
          && (
               !request.resource.data.keys().hasAny(['tag']) ||
               request.resource.data.tag is string
             );
    }

    function isValidUserUpdate() {
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return affectedKeys.hasOnly(['displayName'])
          && request.resource.data.displayName is string;
    }

    function isValidSharedTracker() {
      let required = ['id', 'name', 'createdAt', 'createdBy', 'inviteCode', 'members', 'memberIds'];
      return request.resource.data.keys().hasAll(required)
          && request.resource.data.id         is string
          && request.resource.data.name       is string
          && request.resource.data.name.size() > 0
          && request.resource.data.createdAt  is timestamp
          && request.resource.data.createdBy  is string
          && request.resource.data.inviteCode is string
          && request.resource.data.members    is list
          && request.resource.data.memberIds  is list;
    }

    function isValidSharedTrackerUpdate() {
      let allowed = ['name', 'members', 'memberIds'];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    // Allows a non-member to join by adding only themselves to members/memberIds.
    function isJoiningTracker() {
      let changes = request.resource.data.diff(resource.data).affectedKeys();
      return changes.hasOnly(['members', 'memberIds'])
          && request.auth.uid in request.resource.data.memberIds
          && !(request.auth.uid in resource.data.memberIds);
    }

    function isValidSharedTransaction() {
      let required = ['id', 'title', 'totalAmount', 'date', 'splits'];
      let allowed  = ['id', 'title', 'totalAmount', 'date', 'splits', 'category', 'note', 'tag'];
      return request.resource.data.keys().hasAll(required)
          && request.resource.data.keys().hasOnly(allowed)
          && request.resource.data.id          is string
          && request.resource.data.title       is string
          && request.resource.data.title.size() > 0
          && request.resource.data.totalAmount is number
          && request.resource.data.totalAmount > 0
          && request.resource.data.date        is timestamp
          && request.resource.data.splits      is list
          && (
               !request.resource.data.keys().hasAny(['category']) ||
               request.resource.data.category is string
             )
          && (
               !request.resource.data.keys().hasAny(['note']) ||
               request.resource.data.note is string
             )
          && (
               !request.resource.data.keys().hasAny(['tag']) ||
               request.resource.data.tag is string
             );
    }

    // ========================================
    // USERS COLLECTION
    // ========================================

    match /users/{userId} {
      allow read:   if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserData();
      allow update: if isOwner(userId) && isValidUserUpdate();
      allow delete: if false;

      // EXPENSES subcollection
      match /expenses/{expenseId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidTransaction();
      }

      // INCOMES subcollection
      match /incomes/{incomeId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidTransaction();
      }

      // SAVINGS subcollection
      match /savings/{savingId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidTransaction();
      }

      // CATEGORIES subcollection
      match /categories/{categoryDocId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidCategoryData();
      }
    }

    // ========================================
    // SHARED TRACKERS COLLECTION
    // ========================================

    match /sharedTrackers/{trackerId} {
      // Any member can read their tracker.
      allow read: if isAuthenticated()
          && request.auth.uid in resource.data.memberIds;

      // Creator creates — must include themselves as first member
      allow create: if isAuthenticated()
          && request.auth.uid == request.resource.data.createdBy
          && request.auth.uid in request.resource.data.memberIds
          && isValidSharedTracker();

      // Existing member updates (rename, add/remove members), OR a new user
      // joining via invite code (adds only themselves to members/memberIds)
      allow update: if isAuthenticated() && (
          (request.auth.uid in resource.data.memberIds && isValidSharedTrackerUpdate())
          || isJoiningTracker()
        );

      // Only creator can delete
      allow delete: if isAuthenticated()
          && request.auth.uid == resource.data.createdBy;

      // SHARED TRANSACTIONS subcollection
      match /transactions/{txId} {
        allow read, delete: if isAuthenticated()
            && request.auth.uid in get(/databases/$(database)/documents/sharedTrackers/$(trackerId)).data.memberIds;

        allow create, update: if isAuthenticated()
            && request.auth.uid in get(/databases/$(database)/documents/sharedTrackers/$(trackerId)).data.memberIds
            && isValidSharedTransaction();
      }
    }

    // ========================================
    // INVITE CODES INDEX
    // ========================================

    match /inviteCodes/{code} {
      // Any authenticated user can read (needed to look up trackerId by code)
      allow read: if isAuthenticated();
      // Only the creator writes their own invite code document
      allow create: if isAuthenticated()
          && request.resource.data.createdBy == request.auth.uid;
      allow delete: if isAuthenticated()
          && resource.data.createdBy == request.auth.uid;
      allow update: if false;
    }

    // ========================================
    // DENY ALL OTHER ACCESS
    // ========================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
